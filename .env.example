# Telegram
TELEGRAM_BOT_TOKEN=
MY_TELEGRAM_CHAT_ID=

# Gemini (cost-optimized defaults)
GEMINI_API_KEY=
GEMINI_MODEL_DEFAULT=gemini-2.5-flash-lite
GEMINI_MODEL_HEAVY=gemini-2.5-flash
# Max longest side (px) for images sent to Gemini. 768 = 258 image tokens (1 tile).
GEMINI_IMAGE_MAX_PX=768

# Supabase Postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase Storage (optional, for meal photos)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=meal-photos

# Nutrition defaults
DEFAULT_PROTEIN_TARGET_G=150

# Google Calendar (local file OR cloud JSON)
GOOGLE_CREDENTIALS_JSON=

# One-time migration only (Google Sheets → DB)
SPREADSHEET_ID=
